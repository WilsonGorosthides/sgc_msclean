# Copie este arquivo para ".env" (na mesma pasta) e preencha com os valores
# reais do seu projeto Supabase. O ".env" nunca deve ser commitado (ja esta
# no .gitignore); este arquivo de exemplo serve apenas de referencia.

# URL do projeto Supabase (Project Settings > API > Project URL)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave publica anon do Supabase (Project Settings > API > anon public)
SUPABASE_ANON_KEY=sua-chave-anon-aqui
